<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>POWER DUO</title>
    <!-- VINCULACIÓN AL MANIFIESTO (PARA PWA) -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#FF8C00">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #121212; color: white; -webkit-tap-highlight-color: transparent; }
        .safety-orange { color: #FF8C00; }
        .bg-safety-orange { background-color: #FF8C00; }
        .emerald-green { color: #34D399; }
        .border-emerald { border-color: #34D399; }
    </style>
</head>
<body class="flex flex-col min-h-screen">

    <!-- HEADER INDUSTRIAL (4 ICONOS) -->
    <header class="flex justify-between items-center w-full px-6 py-6 border-b border-[#2A2A2A] sticky top-0 bg-[#121212] z-50">
        <div class="flex gap-6 items-center flex-1 justify-start">
            <button class="text-white text-2xl">←</button> 
            <button class="emerald-green font-black tracking-tighter">DUO</button>
        </div>
        
        <h1 class="text-xl font-black safety-orange uppercase tracking-tighter px-2 text-center">Entrenamiento</h1>
        
        <div class="flex gap-6 items-center flex-1 justify-end">
            <button class="emerald-green text-xl">🌙</button>
            <button class="safety-orange font-black text-xl">✕</button>
        </div>
    </header>

    <main class="p-6 flex-grow">
        <!-- TARJETA DE EJERCICIO -->
        <div class="bg-[#F9F9F9] border-[6px] border-emerald-500 rounded-[3rem] p-10 shadow-2xl relative overflow-hidden">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <span class="bg-black text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest mb-2 inline-block">Misión 01</span>
                    <h2 class="text-3xl font-black text-black uppercase leading-none">Press de <br/>Banca</h2>
                </div>
                <div class="flex flex-col items-end">
                    <span class="safety-orange font-black text-2xl tracking-tighter leading-none">TÚ</span>
                    <div class="w-8 h-1 bg-safety-orange mt-1"></div>
                </div>
            </div>
            
            <!-- MÉTRICAS GIGANTES -->
            <div class="flex gap-12 items-baseline mb-10">
                <div>
                    <p class="emerald-green text-xs font-black uppercase tracking-widest">Series</p>
                    <p class="text-[#121212] text-7xl font-black leading-none">3</p>
                </div>
                <div>
                    <p class="emerald-green text-xs font-black uppercase tracking-widest">Reps</p>
                    <p class="text-[#121212] text-7xl font-black leading-none italic">12</p>
                </div>
            </div>

            <!-- BOTÓN DE ACCIÓN -->
            <button class="w-full bg-safety-orange hover:bg-orange-600 text-white font-black py-6 rounded-2xl shadow-[0_10px_0_rgb(200,100,0)] active:shadow-none active:translate-y-1 transition-all uppercase italic text-xl">
                Máquina Ocupada
            </button>
        </div>

        <!-- INDICADOR DE COMPAÑERO -->
        <div class="mt-8 flex justify-center items-center gap-4">
            <div class="h-[2px] flex-grow bg-[#2A2A2A]"></div>
            <p class="text-[10px] font-black emerald-green uppercase tracking-[0.3em]">Paty en espera...</p>
            <div class="h-[2px] flex-grow bg-[#2A2A2A]"></div>
        </div>
    </main>

    <!-- FOOTER STATUS -->
    <footer class="p-6 border-t border-[#2A2A2A] text-center">
        <p class="text-[9px] text-[#444] font-bold uppercase tracking-[0.5em]">Power Duo Engine v1.0 // Grado Industrial</p>
    </footer>

</body>
</html>
